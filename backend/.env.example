# MongoDB connection string (used by backend)
MONGO_URI=mongodb://127.0.0.1:27017/smart_irrigation

# (Optional) Google Cloud Translate API key
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# Twilio SMS — for automated irrigation alerts
# Sign up free at https://twilio.com to get these
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
