# MongoDB Atlas connection string (replace with your Atlas URI for production)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/smart_irrigation

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# OpenWeather API key
OPENWEATHER_API_KEY=your_openweather_key_here

# Groq AI API key (for chatbot)
GROQ_API_KEY=your_groq_key_here

# Market data API key
MARKET_DATA_API_KEY=your_market_api_key_here

# (Optional) Google Cloud Translate API key
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# Twilio SMS — for automated irrigation alerts
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
